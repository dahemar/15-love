---
import TennisButton from "./TennisButton.astro";
import type { HomeFeedPost } from "../data/siteContent";

interface Props {
  posts?: HomeFeedPost[];
}

const { posts = [] } = Astro.props;

function withEllipsis(text: string): string {
  const trimmed = text.trim();
  return trimmed.length ? `${trimmed}…` : "…";
}
---

<div class="feed" aria-label="Latest posts preview">
  {posts.map((post, index) => (
    <article class="card" id={post.id}>
      <div class={post.images.length ? "content has-media" : "content"}>
        {post.images.length > 0 ? (
          <div class="mediaCol">
            {post.images.slice(0, 2).map((image) => (
              <img
                class="thumb"
                src={image.src}
                alt={image.alt}
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                width="120"
                height="120"
              />
            ))}
          </div>
        ) : null}

        <div class="textCol">
          <h3 class="title">{post.title}</h3>
          <p class="body">{withEllipsis(post.excerpt)}</p>
        </div>
      </div>

      <TennisButton class="card-tennis" href={post.href} label={`Go to ${post.category} post`} />
    </article>
  ))}
</div>

<style>
  .feed {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
  }

  .card {
    position: relative;
    border-left: none;
    border-right: none;
    border-top: 1px solid #000;
    border-bottom: none;
    padding: 12px;
    padding-right: 52px;
    padding-bottom: 44px;
    display: block;
    background: #fff;
    content-visibility: auto;
    contain-intrinsic-size: 240px;
  }

  .card:first-child {
    border-top: none;
  }

  .content {
    min-width: 0;
  }

  .content.has-media {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 12px;
    align-items: start;
  }

  .mediaCol {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .thumb {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border: 1px solid #000;
    display: block;
  }

  .textCol {
    min-width: 0;
  }

  .title {
    margin: 0 0 8px;
    font-size: 16px;
    line-height: 1.25;
    font-weight: 600;
  }

  .body {
    margin: 0;
    font-size: 15px;
    line-height: 1.25;
    white-space: pre-line;
  }

  .card-tennis,
  .card .tennis {
    position: absolute;
    right: 12px;
    bottom: 12px;
  }
</style>