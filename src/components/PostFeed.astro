// Prefer Strapi event posts with images; fall back to any event posts; then hardcoded.
const eventPostsWithMedia = eventPosts.filter((p) =>
  p.eventBlocks.some((b) => b.__component === "events.media" && b.image !== null),
);
const postsToRender: RenderPost[] =
  eventPostsWithMedia.length > 0
    ? eventPostsWithMedia.map(eventPostToCard)
    : eventPosts.length > 0
      ? eventPosts.map(eventPostToCard)
      : HARDCODED;
---

<div class="feed" aria-label="Posts">
  {postsToRender.map((p, i) => (
    <article class={"card kind-" + p.kind} id={p.id}>
      <div class="content">
        {p.kind === "text" ? (
          <>
            {(p as any).title ? <h3 class="postTitle">{(p as any).title}</h3> : null}
            <p class="body">{p.body}</p>
          </>
        ) : null}

        {(p.kind === "image-left" || p.kind === "image-right") ? (
          <>
            <img
              class="media"
              src={p.imageSrc}
              alt={p.imageAlt}
              width="180"
              height="180"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={i === 0 ? "high" : undefined}
            />
            <div class="textSide">
              {p.credits ? (
                <div class="credits" aria-label="Credits">
                  {p.credits.map((c) => (
                    <div class="creditLine">
                      <span class="creditLabel">{c.label}</span> <span class="creditValue">{c.value}</span>
                    </div>
                  ))}
                </div>
              ) : p.details ? (
                <div class="credits" aria-label="Event details">
                  <div class="creditLine detailHeadline">
                    <span class="creditValue">{p.details.headline}</span>
                  </div>
                  {p.details.venue ? (
                    <div class="creditLine">
                      <span class="creditLabel">Venue:</span>{" "}
                      <span class="creditValue">{p.details.venue}</span>
                    </div>
                  ) : null}
                  {p.details.dateLabel ? (
                    <div class="creditLine">
                      <span class="creditLabel">Date:</span>{" "}
                      <span class="creditValue">{p.details.dateLabel}</span>
                    </div>
                  ) : null}
                </div>
              ) : null}
              {p.body ? <p class="body">{p.body}</p> : null}
              {p.caption ? <p class="caption">{p.caption}</p> : null}
            </div>
          </>
        ) : null}

        {p.kind === "gallery" ? (
          <>
            <div class="gallery">
              {p.images.map((img) => (
                <img class="thumb" src={img.src} alt={img.alt} loading="lazy" decoding="async" width="180" height="180" />
              ))}
            </div>
            <p class="body">{p.body}</p>
          </>
        ) : null}
      </div>
      <TennisButton class="card-tennis" href={`#${p.id}`} label="Jump to this post" />
    </article>
  ))}
</div>

<style>
  .feed {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
  }

  .card {
    position: relative;
    border-left: none;
    border-right: none;
    border-top: 1px solid #000;
    border-bottom: none;
    padding: 14px;
    padding-right: 52px;
    padding-bottom: 48px;
    display: block;
    background: #fff;
    content-visibility: auto;
    contain-intrinsic-size: 260px;
  }

  .card:first-child {
    border-top: none;
  }

  .content {
    min-width: 0;
  }

  .body {
    margin: 0;
    font-size: 15.4px; /* +10% */
    line-height: 1.25;
    white-space: pre-line;
  }

  .card-tennis,
  .card .tennis {
    position: absolute;
    right: 12px;
    bottom: 12px;
  }

  .kind-image-left .content,
  .kind-image-right .content {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 14px;
    align-items: start;
  }

  .kind-image-right .content {
    grid-template-columns: 1fr 180px;
  }

  /* For gallery posts: thumbnails in left column, text on the right */
  .kind-gallery .content {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 14px;
    align-items: start;
  }

  .media {
    width: 180px;
    height: 180px;
    object-fit: cover;
    border: 1px solid #000;
  }

  .credits {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 15.4px; /* +10% */
    line-height: 1.25;
  }

  .creditLabel {
    font-family: "TT2020 Style B", "Inter", system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
    letter-spacing: 0.2px;
  }

  .gallery {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 0;
  }

  .thumb {
    width: 180px;
    height: 180px;
    object-fit: cover;
    border: 1px solid #000;
    display: block;
  }

  /* ── Dynamic / Strapi-sourced content ─────────────────────────────────── */

  .textSide {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Reorder image to second column for image-right layout */
  .kind-image-right .media {
    order: 2;
  }

  .postTitle {
    margin: 0;
    font-size: 15.4px;
    font-weight: 600;
    line-height: 1.25;
  }

  .detailHeadline .creditValue {
    font-weight: 600;
  }

  .caption {
    margin: 0;
    font-size: 13px;
    line-height: 1.25;
    color: #555;
    font-style: italic;
  }
</style>
