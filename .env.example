# local = use code-first content in src/data/siteContent.ts
# strapi = fetch content from your Strapi instance (with automatic local fallback)
CMS_MODE=local

# Example: https://your-project-name.strapiapp.com
STRAPI_URL=

# Create an API token in Strapi: Settings -> API Tokens
# For testing, Read-Only is enough if content is already in Strapi.
STRAPI_TOKEN=
